<ui:FluentWindow x:Class="PDM.App.Views.NewDownloadDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="New download detected"
                 Height="330" Width="560"
                 WindowStartupLocation="CenterScreen"
                 Topmost="True"
                 ShowInTaskbar="True"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 ResizeMode="NoResize">

    <DockPanel LastChildFill="True">
        <ui:TitleBar DockPanel.Dock="Top" Title="New download detected" />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="16,8,16,16">
            <ui:Button Content="Cancel"
                       Appearance="Secondary"
                       MinWidth="96"
                       Click="OnCancel" />
            <ui:Button Content="Save for later"
                       Appearance="Secondary"
                       Margin="8,0,0,0"
                       MinWidth="140"
                       Click="OnSaveForLater" />
            <ui:Button Content="Start download"
                       Appearance="Primary"
                       Margin="8,0,0,0"
                       MinWidth="140"
                       IsDefault="True"
                       Click="OnStartDownload" />
        </StackPanel>

        <StackPanel Margin="16,24,16,8">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <ui:SymbolIcon Symbol="ArrowDownload24" Margin="0,0,10,0" VerticalAlignment="Center" />
                <ui:TextBlock FontTypography="Subtitle" Text="Your browser started a new download" />
            </StackPanel>

            <ui:TextBlock Text="File" FontSize="12" Opacity="0.7" Margin="0,0,0,2" />
            <Border Padding="8,6" CornerRadius="4" Margin="0,0,0,10"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <ui:TextBlock Text="{Binding FileName}" TextWrapping="Wrap"
                              FontFamily="Consolas" FontSize="12" />
            </Border>

            <ui:TextBlock Text="Source" FontSize="12" Opacity="0.7" Margin="0,0,0,2" />
            <Border Padding="8,6" CornerRadius="4" Margin="0,0,0,12"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <ui:TextBlock Text="{Binding UrlText}" TextWrapping="Wrap"
                              FontFamily="Consolas" FontSize="12" />
            </Border>

            <ui:TextBlock Opacity="0.7" FontSize="12" TextWrapping="Wrap"
                          Text="Start it now, park it for later, or dismiss it. You can turn off these prompts under Settings if you want browser downloads to auto-start." />
        </StackPanel>
    </DockPanel>
</ui:FluentWindow>
