<ui:FluentWindow x:Class="PDM.App.Views.UpdateAvailableDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Update Available"
                 Height="440" Width="560"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 ResizeMode="NoResize">

    <DockPanel LastChildFill="True">
        <ui:TitleBar DockPanel.Dock="Top" Title="Update Available" />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="16,8,16,16">
            <ui:Button Content="Later"
                       Appearance="Secondary"
                       MinWidth="96"
                       Click="OnLater" />
            <ui:Button x:Name="DownloadButton"
                       Content="Download and Install"
                       Appearance="Primary"
                       MinWidth="180"
                       Margin="8,0,0,0"
                       IsDefault="True"
                       Command="{Binding DownloadCommand}"
                       Visibility="{Binding IsComplete, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
            <ui:Button x:Name="RestartButton"
                       Content="Restart to Apply"
                       Appearance="Primary"
                       MinWidth="180"
                       Margin="8,0,0,0"
                       IsDefault="True"
                       Click="OnRestart"
                       Visibility="{Binding IsComplete, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <StackPanel Margin="16,20,16,8">
            <ui:TextBlock FontTypography="Subtitle" Text="{Binding Title}" Margin="0,0,0,4" />
            <ui:TextBlock FontSize="12" Opacity="0.7" Text="{Binding SizeText, StringFormat='Package size: {0}'}" Margin="0,0,0,10" />

            <ui:TextBlock FontTypography="BodyStrong" Text="Release notes" Margin="0,0,0,4" />
            <Border Padding="10" CornerRadius="4"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="160">
                    <ui:TextBlock Text="{Binding ReleaseNotes}" TextWrapping="Wrap" FontSize="12" />
                </ScrollViewer>
            </Border>

            <Grid Margin="0,14,0,0"
                  Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ui:TextBlock Grid.Row="0" Text="{Binding StatusText}" Margin="0,0,0,4" />
                <ProgressBar Grid.Row="1" Height="6"
                             Minimum="0" Maximum="100"
                             Value="{Binding ProgressPercent, Mode=OneWay}" />
            </Grid>

            <ui:TextBlock Text="{Binding StatusText}"
                          Margin="0,14,0,0"
                          Visibility="{Binding IsComplete, Converter={StaticResource BoolToVis}}" />
            <ui:TextBlock Foreground="#E38B00"
                          Text="{Binding ErrorMessage}"
                          TextWrapping="Wrap"
                          Margin="0,8,0,0"
                          Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}" />
        </StackPanel>
    </DockPanel>
</ui:FluentWindow>
