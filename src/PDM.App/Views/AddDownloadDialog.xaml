<ui:FluentWindow x:Class="PDM.App.Views.AddDownloadDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Add Download"
                 Height="220" Width="560"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 ResizeMode="NoResize">

    <Grid Margin="16,32,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TextBlock Grid.Row="0" FontTypography="BodyStrong" Text="Download URL" Margin="0,0,0,6" />

        <ui:TextBox x:Name="UrlBox"
                    Grid.Row="1"
                    PlaceholderText="https://example.com/file.zip"
                    Padding="8"
                    KeyDown="OnUrlBoxKeyDown" />

        <ui:TextBlock Grid.Row="2"
                      Margin="0,10,0,0"
                      Text="Detected category will apply automatically. Files save into the category folder."
                      Opacity="0.7"
                      TextWrapping="Wrap" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <ui:Button Content="Cancel"
                       Appearance="Secondary"
                       MinWidth="96"
                       Click="OnCancel" />
            <ui:Button x:Name="OkButton"
                       Content="Add Download"
                       Appearance="Primary"
                       MinWidth="140"
                       Margin="8,0,0,0"
                       IsDefault="True"
                       Click="OnOk" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
