<ui:FluentWindow x:Class="PDM.App.Views.BrowserSetupWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Browser Setup"
                 Height="560" Width="720"
                 MinHeight="480" MinWidth="640"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">

    <DockPanel LastChildFill="True">
        <ui:TitleBar DockPanel.Dock="Top" Title="Browser Setup" />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="16,8,16,16">
            <ui:Button Content="Remove PDM from all browsers"
                       Appearance="Secondary"
                       Command="{Binding UnregisterAllCommand}" />
            <ui:Button Content="Close"
                       Appearance="Primary"
                       MinWidth="96"
                       Margin="8,0,0,0"
                       IsDefault="True"
                       Click="OnClose" />
        </StackPanel>

        <StackPanel Margin="16,20,16,8">
            <ui:TextBlock FontTypography="Subtitle" Text="Send downloads from your browser to PDM" Margin="0,0,0,4" />
            <ui:TextBlock FontSize="12" Opacity="0.75" TextWrapping="Wrap" Margin="0,0,0,4"
                          Text="For each browser below: (1) open the extension page, (2) install the PDM extension, (3) paste its ID and register." />
            <ui:TextBlock FontSize="12" Opacity="0.6" Text="{Binding SummaryText}" Margin="0,0,0,12" />

            <ItemsControl ItemsSource="{Binding Browsers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10" Padding="12" CornerRadius="6"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ui:TextBlock Grid.Row="0" Grid.Column="0"
                                              FontTypography="BodyStrong" Text="{Binding DisplayName}" />
                                <ui:Button Grid.Row="0" Grid.Column="1"
                                           Content="1. Install extension"
                                           MinWidth="150"
                                           Command="{Binding DataContext.OpenStorePageCommand,
                                                     RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                           CommandParameter="{Binding}" />

                                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox Grid.Column="0"
                                                PlaceholderText="Paste the extension ID from chrome://extensions"
                                                FontFamily="Consolas"
                                                Text="{Binding ExtensionId, UpdateSourceTrigger=PropertyChanged}" />
                                    <ui:Button Grid.Column="1"
                                               Content="2. Register with PDM"
                                               Margin="8,0,0,0"
                                               MinWidth="160"
                                               Appearance="Primary"
                                               Command="{Binding DataContext.RegisterCommand,
                                                         RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                               CommandParameter="{Binding}" />
                                </Grid>

                                <ui:TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                                              Margin="0,6,0,0" FontSize="12"
                                              Opacity="0.75"
                                              TextWrapping="Wrap"
                                              Text="{Binding Status}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </DockPanel>
</ui:FluentWindow>
