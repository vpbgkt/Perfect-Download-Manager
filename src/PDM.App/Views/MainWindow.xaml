<ui:FluentWindow x:Class="PDM.App.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:PDM.App.ViewModels"
                 xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                 xmlns:tray="clr-namespace:Wpf.Ui.Tray.Controls;assembly=Wpf.Ui.Tray"
                 Title="{Binding AppTitle}"
                 Height="720" Width="1200"
                 MinHeight="480" MinWidth="900"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 AllowDrop="True"
                 DragEnter="OnDragEnter"
                 Drop="OnDrop">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- In-app toast/snackbar overlay - shown for download completions so the user
             always gets a visible confirmation even if OS balloon tips are suppressed. -->
        <ui:SnackbarPresenter x:Name="SnackbarHost" Grid.RowSpan="3" Panel.ZIndex="1000" />

        <!-- Title bar with app title (includes version) and icon. -->
        <ui:TitleBar Grid.Row="0" Title="{Binding AppTitle}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/pdm.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- License / trial banner. Colours it with an amber tint when a call to action is due. -->
        <Border Grid.Row="1"
                Margin="12,8,12,4"
                Padding="12,8"
                CornerRadius="6"
                DataContext="{Binding LicenseBanner}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsWarning}" Value="True">
                            <Setter Property="Background" Value="#33E38B00" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Grid.Column="0" Symbol="Key24" Margin="0,0,10,0" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <ui:TextBlock FontTypography="BodyStrong" Text="{Binding StatusText}" />
                    <ui:TextBlock FontSize="12" Opacity="0.75" Text="{Binding DetailText}" />
                </StackPanel>
                <ui:Button Grid.Column="2"
                           Appearance="Secondary"
                           MinWidth="120"
                           Content="{Binding ActionLabel}"
                           Visibility="{Binding IsActionVisible, Converter={StaticResource BoolToVis}}"
                           Click="OnOpenLicense" />
            </Grid>
        </Border>

        <!-- Tray icon shown while the window is minimized/hidden -->
        <tray:NotifyIcon x:Name="TrayIcon"
                         Grid.Row="0"
                         Grid.RowSpan="1"
                         Icon="pack://application:,,,/Assets/pdm.ico"
                         TooltipText="Perfect Download Manager"
                         LeftClick="OnTrayOpen">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <MenuItem Header="Open PDM" Click="OnTrayOpen" />
                    <Separator />
                    <MenuItem Header="Add download..." Click="OnAddDownload" />
                    <Separator />
                    <MenuItem Header="Exit" Click="OnTrayExit" />
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>

        <!-- Body: sidebar + main area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--
              Sidebar: category filter list. Given a subtle two-tone contrast from the main
              area so the boundary is visible without dominating the Mica window.
            -->
            <Border Grid.Column="0"
                    Padding="12"
                    Background="{DynamicResource SolidBackgroundFillColorTertiaryBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <StackPanel>
                    <ui:TextBlock FontTypography="Subtitle" Text="Library" Margin="0,0,0,8" />
                    <ListBox x:Name="CategoryList"
                             ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory}"
                             DisplayMemberPath="Label"
                             Background="Transparent"
                             BorderThickness="0" />
                </StackPanel>
            </Border>

            <!-- Main area: toolbar, search, grid -->
            <Grid Grid.Column="1" Margin="0,0,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--
                  Toolbar - the primary download actions live on the left; less-frequent
                  actions (Settings, License, Browser Setup, Updates) live under a "More"
                  menu on the right so the row never overflows when the window shrinks.
                -->
                <DockPanel Grid.Row="0" Margin="0,8,0,8" LastChildFill="False">
                    <ui:Button DockPanel.Dock="Right"
                               x:Name="MoreMenuButton"
                               Content="More"
                               Appearance="Secondary"
                               Icon="{ui:SymbolIcon MoreHorizontal24}"
                               Click="OnMoreMenu">
                        <ui:Button.ContextMenu>
                            <ContextMenu Placement="Bottom">
                                <MenuItem Header="Settings" Click="OnOpenSettings" />
                                <MenuItem Header="License" Click="OnOpenLicense" />
                                <MenuItem Header="Browser Setup" Click="OnBrowserSetup" />
                                <Separator />
                                <MenuItem Header="Check for Updates" Click="OnCheckForUpdates" />
                            </ContextMenu>
                        </ui:Button.ContextMenu>
                    </ui:Button>

                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Add Download"
                                   Appearance="Primary"
                                   Icon="{ui:SymbolIcon Add24}"
                                   Click="OnAddDownload" />
                        <ui:Button Content="Add Many"
                                   Appearance="Secondary"
                                   Margin="8,0,0,0"
                                   Icon="{ui:SymbolIcon AddCircle24}"
                                   Click="OnBulkAdd" />
                        <ui:Button Margin="8,0,0,0"
                                   Content="Resume"
                                   Icon="{ui:SymbolIcon Play24}"
                                   Command="{Binding ResumeCommand}"
                                   CommandParameter="{Binding SelectedItem}" />
                        <ui:Button Margin="8,0,0,0"
                                   Content="Pause"
                                   Icon="{ui:SymbolIcon Pause24}"
                                   Command="{Binding PauseCommand}"
                                   CommandParameter="{Binding SelectedItem}" />
                        <ui:Button Margin="8,0,0,0"
                                   Content="Remove"
                                   Appearance="Secondary"
                                   Icon="{ui:SymbolIcon Delete24}"
                                   Click="OnRemoveSelected" />
                    </StackPanel>
                </DockPanel>

                <!--
                  Search box - narrow (about 40% of the toolbar width), left-aligned, with a
                  leading Search icon so users don't confuse it with an "add download" field.
                -->
                <ui:TextBox Grid.Row="1"
                            PlaceholderText="Search downloads"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                            Icon="{ui:SymbolIcon Search24}"
                            IconPlacement="Left"
                            MaxWidth="340"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,8" />

                <!-- The grid + empty-state overlay share Row 2. The overlay appears when
                     the filtered view has no rows (per category, per search). -->
                <Grid Grid.Row="2">

                <!-- Downloads grid. Both horizontal and vertical grid lines are drawn in a
                     subtle stroke colour so rows and columns are easier to scan without
                     overwhelming the Fluent look. -->
                <DataGrid x:Name="DownloadsGrid"
                          ItemsSource="{Binding Downloads}"
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          HorizontalGridLinesBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                          VerticalGridLinesBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          RowHeight="42">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding FileName}" Width="2*" />
                        <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="90" />
                        <DataGridTemplateColumn Header="Progress" Width="220">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center">
                                        <ProgressBar Height="6" Minimum="0" Maximum="100"
                                                     Value="{Binding ProgressPercent, Mode=OneWay}" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Downloaded" Binding="{Binding DownloadedText}" Width="150" />
                        <DataGridTextColumn Header="Speed" Binding="{Binding SpeedText}" Width="100" />
                        <DataGridTextColumn Header="ETA" Binding="{Binding EtaText}" Width="90" />
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusLabel}" Width="140" />
                        <DataGridTextColumn Header="Connections" Binding="{Binding ConnectionsText}" Width="100" />
                    </DataGrid.Columns>

                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Resume"
                                      Command="{Binding PlacementTarget.DataContext.ResumeCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="Pause"
                                      Command="{Binding PlacementTarget.DataContext.PauseCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <Separator />
                            <MenuItem Header="Open"
                                      Command="{Binding PlacementTarget.DataContext.OpenFileCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="Show in folder"
                                      Command="{Binding PlacementTarget.DataContext.OpenFolderCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <Separator />
                            <MenuItem Header="Remove / Delete..." Click="OnRemoveSelected" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <!-- Empty-state overlay, shown when the filtered list has no rows. -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            Visibility="{Binding IsListEmpty, Converter={StaticResource BoolToVis}}">
                    <ui:SymbolIcon Symbol="Box24"
                                   FontSize="48"
                                   Opacity="0.35"
                                   HorizontalAlignment="Center" />
                    <ui:TextBlock FontTypography="Subtitle"
                                  HorizontalAlignment="Center"
                                  Margin="0,8,0,4"
                                  Text="{Binding EmptyStateTitle}" />
                    <ui:TextBlock Opacity="0.7"
                                  HorizontalAlignment="Center"
                                  Text="{Binding EmptyStateHint}" />
                </StackPanel>

                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
