<ui:FluentWindow x:Class="PDM.App.Views.ExtensionInstallHelpDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Install PDM extension"
                 Height="520" Width="620"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 ResizeMode="NoResize">

    <DockPanel LastChildFill="True">
        <ui:TitleBar DockPanel.Dock="Top" Title="Install PDM browser extension" />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="16,8,16,16">
            <ui:Button Content="Copy folder path"
                       Appearance="Secondary"
                       MinWidth="140"
                       Click="OnCopyPath" />
            <ui:Button Content="Open extension folder"
                       Appearance="Secondary"
                       Margin="8,0,0,0"
                       MinWidth="180"
                       Click="OnOpenFolder" />
            <ui:Button Content="Open browser"
                       Appearance="Primary"
                       Margin="8,0,0,0"
                       MinWidth="140"
                       IsDefault="True"
                       Click="OnOpenBrowser" />
        </StackPanel>

        <ScrollViewer Padding="20,20,20,8" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <ui:TextBlock FontTypography="Subtitle" Text="{Binding BrowserName, StringFormat='Add the PDM extension to {0}'}"
                              Margin="0,0,0,4" />
                <ui:TextBlock Opacity="0.75" TextWrapping="Wrap" Margin="0,0,0,16"
                              Text="Until the extension is published to the store, follow these three steps once. It takes about 30 seconds." />

                <!-- Step 1 -->
                <Border Padding="12" CornerRadius="6" Margin="0,0,0,10"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="Step 1 — Enable Developer mode" />
                        <ui:TextBlock Opacity="0.85" TextWrapping="Wrap" Margin="0,4,0,0"
                                      Text="When the browser opens its extensions page, turn on the 'Developer mode' toggle in the top-right corner. You only need to do this once." />
                    </StackPanel>
                </Border>

                <!-- Step 2 -->
                <Border Padding="12" CornerRadius="6" Margin="0,0,0,10"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="Step 2 — Drag the extension folder onto the page" />
                        <ui:TextBlock Opacity="0.85" TextWrapping="Wrap" Margin="0,4,0,6"
                                      Text="We're opening Windows Explorer at the extension folder for you. Drag the 'chromium' folder from Explorer onto the browser's extensions page - the browser will install it instantly." />
                        <Border Padding="8,6" CornerRadius="4"
                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                            <ui:TextBlock FontFamily="Consolas" FontSize="12"
                                          TextWrapping="Wrap"
                                          Text="{Binding ExtensionFolder}" />
                        </Border>
                        <ui:TextBlock Opacity="0.6" FontSize="11" Margin="0,4,0,0"
                                      Text="Prefer to click? Use 'Load unpacked' in the extensions page and paste the copied path." />
                    </StackPanel>
                </Border>

                <!-- Step 3 -->
                <Border Padding="12" CornerRadius="6" Margin="0,0,0,10"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="Step 3 — Copy the extension ID back into PDM" />
                        <ui:TextBlock Opacity="0.85" TextWrapping="Wrap" Margin="0,4,0,0"
                                      Text="After the extension appears in the list, copy the ID (32 lowercase letters) shown beneath its name and paste it into the wizard row in PDM, then click 'Register with PDM'." />
                    </StackPanel>
                </Border>

                <ui:TextBlock Opacity="0.65" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"
                              Text="This process disappears once we publish the extension to the Chrome Web Store - you'll then be able to add it with a single click." />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</ui:FluentWindow>
