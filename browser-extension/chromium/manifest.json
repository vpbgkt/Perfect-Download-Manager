{
  "manifest_version": 3,
  "name": "Perfect Download Manager Integration",
  "version": "1.0.9",
  "description": "Send downloads and links to Perfect Download Manager (PDM).",
  "permissions": [
    "downloads",
    "contextMenus",
    "nativeMessaging",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Perfect Download Manager",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
