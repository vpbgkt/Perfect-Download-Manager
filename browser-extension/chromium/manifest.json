{
  "manifest_version": 3,
  "name": "Perfect Download Manager Integration",
  "version": "1.2.5",
  "description": "Send downloads, links and media to Perfect Download Manager (PDM) — a fast multi-connection download manager for Windows.",
  "author": "Perfect Download Manager",
  "homepage_url": "https://github.com/vpbgkt/Perfect-Download-Manager",
  "minimum_chrome_version": "102",
  "permissions": [
    "downloads",
    "contextMenus",
    "nativeMessaging",
    "notifications",
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Perfect Download Manager",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "send-current-tab": {
      "suggested_key": {
        "default": "Alt+Shift+P"
      },
      "description": "Send the current tab to Perfect Download Manager"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
