# .NET build output
bin/
obj/
[Dd]ebug/
[Rr]elease/
artifacts/
publish/
out/
dist/

# dotnet local tool manifest is fine to commit; obfuscated output is not
**/obfuscated/

# WiX toolset extension cache (auto-downloaded per machine)
.wix/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# IDE
.vs/
.vscode/
.idea/
*.DotSettings.user

# Test results
[Tt]est[Rr]esults/
*.trx
*.coverage
coverage/

# PDM runtime artifacts (local state — never commit)
downloads/
smoketest/
*.pdmdownload
*.pdmstate

# Temp log files captured during dev
*.log

# OS
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
$RECYCLE.BIN/

# Windows Installer logs
*.msi.log

# Node / backend
node_modules/
backend/**/lambda.zip
backend/**/_keygen.mjs
backend/**/_derive-pub.mjs
*.pem

# Local scratch
stack-info.json
deploy-out.log
pubkey.txt
testkey.txt
activate-resp.json
vector.json
